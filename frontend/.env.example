# API base URL (include /api). For local dev you can leave unset and use Vite proxy + relative paths.
VITE_API_URL=/api

# Optional: Google Maps JavaScript API key for satellite intro map (smooth zoom + marker).
# Without it, PropertyIntro falls back to an iframe embed (still works).
VITE_GOOGLE_MAPS_API_KEY=

# Optional: URL to a short ambient audio loop for the intro (starts muted; user can unmute).
VITE_INTRO_AMBIENT_AUDIO_URL=
